      <Placemark>
        <name>Semmel Bogner Anna
</name>
        <description>Tynya Semmel, figlia di Marco Semmel e Anna Bogner è nata in Polonia a Tarnopol il 17 settembre 1904. Arrestata a Ponte Tresa (Varese). Deportata nel campo di sterminio di Auschwitz. Non è sopravvissuta alla Shoah.</description>
        <styleUrl>#icon-1592-F57C00</styleUrl>
        <Point>
          <coordinates>
            9.2086895,45.4741162,0
          </coordinates>
        </Point>
